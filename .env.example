# Local standalone dev only (NOT used by the embedded HA panel — that inherits auth).
# Copy this file to `.env.local` and fill in a token.
# Create a token in Home Assistant: Profile → Security → Long-lived access tokens.
#
# Note: connecting a browser dev server to a remote HA requires that HA allow the
# dev origin via the `http: cors_allowed_origins:` config (e.g. http://localhost:5173).

VITE_HASS_URL=https://ha-mcp-demo-server.qc-h.net
VITE_HASS_TOKEN=
